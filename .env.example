# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit your real keys.

# Required: Cohere API key, used for both embeddings and the LLM.
# Get one at https://dashboard.cohere.com/
COHERE_API_KEY=your_cohere_api_key_here

# Required for JWT auth in the FastAPI layer. Use any long random string.
SECRET_KEY=change_me_to_a_long_random_string

# SQLAlchemy URL for the auth/user store (defaults to a local SQLite file).
DATABASE_URL=sqlite:///./rag_system.db
